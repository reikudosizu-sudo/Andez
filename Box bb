-- Update List (Klik untuk ON/OFF)
local function updateList()
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    local searchText = searchBox.Text:lower()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player then
            if searchText == "" or p.DisplayName:lower():find(searchText) or p.Name:lower():find(searchText) then
                local pBtn = Instance.new("TextButton", scrollFrame)
                pBtn.Size = UDim2.new(1, -10, 0, 28)
                pBtn.Text = p.DisplayName
                pBtn.TextSize = 11 
                pBtn.BackgroundColor3 = (currentTarget == p.Name) and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
                pBtn.TextColor3 = Color3.new(1, 1, 1)
                pBtn.Font = Enum.Font.SourceSans
                Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 4)
                
                pBtn.MouseButton1Click:Connect(function()
                    currentTarget = (currentTarget == p.Name) and nil or p.Name
                    updateList()
                end)
            end
        end
    end
end

searchBox:GetPropertyChangedSignal("Text"):Connect(updateList)

-- Main Loop
runService.RenderStepped:Connect(function()
    if currentTarget and player.Character then
        local targetP = game.Players:FindFirstChild(currentTarget)
        if targetP and targetP.Character and targetP.Character:FindFirstChild("HumanoidRootPart") then
            local tHrp = targetP.Character.HumanoidRootPart
            local myHrp = player.Character:FindFirstChild("HumanoidRootPart")
            tHrp.Size = Vector3.new(4, 4, 4)
            tHrp.Transparency = 1
            if myHrp then
                local distance = (myHrp.Position - tHrp.Position).Magnitude
                statusLabel.Text = "Tgt: " .. targetP.DisplayName:sub(1,10) .. " | Dist: " .. math.floor(distance)
                sBox.Color3 = (distance <= PUNCH_DISTANCE) and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
            end
            sBox.Adornee = targetP.Character
        else sBox.Adornee = nil end
    else
        sBox.Adornee = nil
        statusLabel.Text = "Target: None | Dist: 0"
    end
end)

