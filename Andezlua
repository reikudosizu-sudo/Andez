local function MakeNeon(obj)
    task.spawn(function()
        local h = 0
        while obj and obj.Parent do
            h = h + 0.01; if h >= 1 then h = 0 end
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                obj.TextColor3 = Color3.fromHSV(h, 1, 1)
            end
            task.wait(0.05)
        end
    end)
end

local function ClearAllESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character then
            for _, child in pairs(p.Character:GetChildren()) do
                if child.Name == "AndezESP" or child:IsA("Highlight") then
                    child:Destroy()
                end
            end
        end
    end
end

local function TotalKill()
    _G.nc = false; _G.SpecLoop = false; _G.ESPActive = false; _G.JumpEnabled = false; _G.AntiFling = false
    ClearAllESP()
    if _G.NoclipConn then _G.NoclipConn:Disconnect() _G.NoclipConn = nil end
    if _G.AntiFlingConn then _G.AntiFlingConn:Disconnect() _G.AntiFlingConn = nil end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        Camera.CameraSubject = LocalPlayer.Character.Humanoid
    end
    for _, ui in pairs(game.CoreGui:GetChildren()) do if ui.Name:find("AndezVip") or ui.Name:find("AndezFling") then ui:Destroy() end end
end

