            sTitle.Size = UDim2.new(1, -16, 0, 20)
            sTitle.Text = secName:upper()
            sTitle.TextColor3 = Miyako_Theme.SchemeColor
            sTitle.Font = Enum.Font.GothamBold 
            sTitle.TextSize = 12
            sTitle.BackgroundTransparency = 1
            table.insert(Elements_To_Update.Indicators, sTitle)

            il:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                sFrame.Size = UDim2.new(1, -10, 0, il.AbsoluteContentSize.Y + 20)
            end)

            local El = {}
            function El:NewToggle(text, cb)
                local st = false
                local b = Instance.new("TextButton", sFrame)
                b.Size = UDim2.new(1, -16, 0, 38)
                b.BackgroundColor3 = Miyako_Theme.Background
                b.Text = "  " .. text
                b.TextColor3 = Miyako_Theme.TextColor
                b.Font = Enum.Font.GothamBold
                b.TextSize = 13 
                b.TextXAlignment = "Left"
                Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
                CreateRipple(b) 
                
                local sBg = Instance.new("Frame", b)
                sBg.Size = UDim2.new(0, 45, 0, 20)
                sBg.Position = UDim2.new(1, -55, 0.5, -10)
                sBg.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
                Instance.new("UICorner", sBg).CornerRadius = UDim.new(1, 0)

                b.MouseButton1Click:Connect(function()
                    st = not st
                    sBg.BackgroundColor3 = st and Miyako_Theme.SchemeColor or Color3.fromRGB(45, 45, 50)
                    cb(st)
                end)
            end

            function El:NewButton(text, cb)
                local b = Instance.new("TextButton", sFrame)
                b.Size = UDim2.new(1, -16, 0, 38)
                b.BackgroundColor3 = Miyako_Theme.Background
                b.Text = text
                b.TextColor3 = Miyako_Theme.TextColor
                b.Font = Enum.Font.GothamMedium 
                b.TextSize = 13 
                Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
                CreateRipple(b) 
                b.MouseButton1Click:Connect(function() cb(b) end)
            end

            function El:NewMusicPanel(playlistData, onSelected)
                local toggleBtn = Instance.new("TextButton", sFrame)
                toggleBtn.Size = UDim2.new(1, -16, 0, 40)
                toggleBtn.BackgroundColor3 = Miyako_Theme.Background
                toggleBtn.Text = "📂 Open Playlist"
                toggleBtn.TextColor3 = Miyako_Theme.TextColor
                toggleBtn.Font = Enum.Font.GothamBold
                toggleBtn.TextSize = 14
                Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 8)
                CreateRipple(toggleBtn) 

                local Panel = Instance.new("Frame", ScreenGui)
                Panel.Size = UDim2.new(0, 240, 0, 300)
                Panel.Position = UDim2.new(0.5, -120, 0.5, -150)
                Panel.BackgroundColor3 = Miyako_Theme.Background
                Panel.Visible = false
                Panel.ZIndex = 1000 
                Instance.new("UICorner", Panel).CornerRadius = UDim.new(0, 15)
                local PanelStroke = Instance.new("UIStroke", Panel)
                PanelStroke.Color = Miyako_Theme.SchemeColor
                table.insert(Elements_To_Update.Strokes, PanelStroke)

                local P_Scroll = Instance.new("ScrollingFrame", Panel)
                P_Scroll.Size = UDim2.new(1, -10, 1, -55)
                P_Scroll.Position = UDim2.new(0, 5, 0, 48)
                P_Scroll.BackgroundTransparency = 1
                P_Scroll.ScrollBarThickness = 2
                local P_List = Instance.new("UIListLayout", P_Scroll)
                P_List.Padding = UDim.new(0, 6)

                for i, song in ipairs(playlistData) do
                    local sBtn = Instance.new("TextButton", P_Scroll)
                    sBtn.Size = UDim2.new(1, -10, 0, 32)
                    sBtn.BackgroundColor3 = Miyako_Theme.ElementColor
                    sBtn.Text = "  " .. i .. ". " .. song.Name
                    sBtn.TextColor3 = Miyako_Theme.TextColor
                    sBtn.Font = Enum.Font.GothamMedium
                    sBtn.TextSize = 11
                    sBtn.TextXAlignment = "Left"
                    Instance.new("UICorner", sBtn).CornerRadius = UDim.new(0, 6)
                    CreateRipple(sBtn)
                    SongButtons[i] = sBtn
                    sBtn.MouseButton1Click:Connect(function() onSelected(i) end)
                end

                toggleBtn.MouseButton1Click:Connect(function() Panel.Visible = not Panel.Visible end)
                local closeX = Instance.new("TextButton", Panel)
                closeX.Size = UDim2.new(0, 25, 0, 25)
                closeX.Position = UDim2.new(1, -30, 0, 10)
                closeX.Text = "X"
                closeX.TextColor3 = Color3.fromRGB(220, 50, 50)
                closeX.BackgroundTransparency = 1
                closeX.MouseButton1Click:Connect(function() Panel.Visible = false end)
            end

            function El:NewVolumeSlider()
                local VolFrame = Instance.new("Frame", sFrame)
                VolFrame.Size = UDim2.new(1, -16, 0, 50)
                VolFrame.BackgroundColor3 = Miyako_Theme.Background
                Instance.new("UICorner", VolFrame).CornerRadius = UDim.new(0, 8)

                local SliderFill = Instance.new("Frame", VolFrame)
                SliderFill.Size = UDim2.new(BGM.Volume, 0, 0, 4)
                SliderFill.Position = UDim2.new(0.1, 0, 0.7, 0)
                SliderFill.BackgroundColor3 = Miyako_Theme.SchemeColor
                
                local MinusBtn = Instance.new("TextButton", VolFrame)
                MinusBtn.Size = UDim2.new(0, 30, 0, 30)
                MinusBtn.Text = "-"
                MinusBtn.TextColor3 = Miyako_Theme.TextColor
                MinusBtn.BackgroundTransparency = 1
                MinusBtn.MouseButton1Click:Connect(function() 
                    BGM.Volume = math.clamp(BGM.Volume - 0.1, 0, 1)
                    SliderFill.Size = UDim2.new(BGM.Volume, 0, 0, 4)
                end)
            end
            return El
        end
        return Sections
    end
    
    function MIYAKO:ChangeTheme(newColor)
        Miyako_Theme.SchemeColor = newColor
        for _, v in pairs(Elements_To_Update.Strokes) do v.Color = newColor end
        for _, v in pairs(Elements_To_Update.Indicators) do v.TextColor3 = newColor end
    end

    --// INITIAL FEATURES
    local MainTab = Tabs:NewTab("Main")
    local Mov = MainTab:NewSection("Player Movement")
    Mov:NewToggle("Infinite Jump", function(s) _G.IJ = s end)
    game:GetService("UserInputService").JumpRequest:Connect(function()
        if _G.IJ and lp.Character then 
            local h = lp.Character:FindFirstChildOfClass("Humanoid")
            if h then h:ChangeState("Jumping") end
        end
    end)

    local SetTab = Tabs:NewTab("Settings")
    local MusicSec = SetTab:NewSection("Music Player")
    MusicSec:NewToggle("Miyako Music 😜", function(state)
        isPlaying = state
        if state then BGM.SoundId = "rbxassetid://" .. Playlist[curTrack].ID BGM:Play() else BGM:Stop() end
    end)
    MusicSec:NewMusicPanel(Playlist, function(index) 
        curTrack = index 
        if isPlaying then BGM:Stop() BGM.SoundId = "rbxassetid://" .. Playlist[curTrack].ID BGM:Play() end
    end)

    SendNotification("MIYAKO IS READY", "Hello, " .. lp.DisplayName .. "! HUB is Loaded.", 6)

    return Tabs -- <--- INI KUNCI UTAMA LIBRARY
end

return MIYAKO
