local MiyakoLib = loadstring(game:HttpGet("URL_LINK_GITHUB_KAMU"))()

-- Membuat Window/Lib Utama
local Lib = MiyakoLib.CreateLib()

-- Menambah Tab Baru (Contoh: Fitur Farm)
local TabFarm = Lib:NewTab("Auto Farm")
local FarmSec = TabFarm:NewSection("Leveling")

FarmSec:NewToggle("Auto Quest", function(state)
    print("Auto Quest is: ", state)
    -- Masukkan logika script auto farm kamu di sini
end)

FarmSec:NewButton("Kill All Mobs", function()
    print("Killing all mobs...")
end)

-- Menambah Tab Lain (Contoh: Fitur Teleport)
local TabTP = Lib:NewTab("Teleport")
local TPSec = TabTP:NewSection("World Locations")

TPSec:NewButton("Teleport to Spawn", function()
    game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(0, 50, 0)
end)
