--// UTILITY: RIPPLE
local function CreateRipple(button)
    button.ClipsDescendants = true
    button.MouseButton1Down:Connect(function()
        local mousePos = input:GetMouseLocation()
        local relativePos = mousePos - button.AbsolutePosition - Vector2.new(0, 36)
        local ripple = Instance.new("Frame")
        ripple.Name = "Ripple"
        ripple.Parent = button
        ripple.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        ripple.BackgroundTransparency = 0.6
        ripple.Size = UDim2.new(0, 0, 0, 0)
        ripple.Position = UDim2.new(0, relativePos.X, 0, relativePos.Y)
        ripple.AnchorPoint = Vector2.new(0.5, 0.5)
        ripple.ZIndex = button.ZIndex + 1
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = ripple
        local targetSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 1.5
        tween:Create(ripple, TweenInfo.new(0.5, Enum.EasingStyle.QuadOut), {
            Size = UDim2.new(0, targetSize, 0, targetSize),
            BackgroundTransparency = 1
        }):Play()
        task.delay(0.5, function() ripple:Destroy() end)
    end)
end

--// SYSTEM: GLOBAL PARTICLE
local function CreateParticles(parent, count)
    local ParticleContainer = Instance.new("Frame", parent)
    ParticleContainer.Size = UDim2.new(1, 0, 1, 0)
    ParticleContainer.BackgroundTransparency = 1
    ParticleContainer.ClipsDescendants = true
    ParticleContainer.ZIndex = 1

    for i = 1, (count or 30) do
        local p = Instance.new("Frame", ParticleContainer)
        p.Size = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
        p.BackgroundColor3 = Miyako_Theme.SchemeColor
        p.BackgroundTransparency = 0.5
        Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)
        table.insert(Elements_To_Update.Particles, p)
        
        local function Move()
            local targetPos = UDim2.new(math.random(), 0, math.random(), 0)
            local speed = math.random(8, 16)
            local t = tween:Create(p, TweenInfo.new(speed, Enum.EasingStyle.Linear), {Position = targetPos, BackgroundTransparency = math.random(0.4, 0.8)})
            t:Play()
            t.Completed:Connect(Move)
        end
        p.Position = UDim2.new(math.random(), 0, math.random(), 0)
        Move()
    end
end

--// DRAGGING
function MIYAKO:DraggingEnabled(frame, parent)
    parent = parent or frame
    local dragging, dragInput, mousePos, framePos
    frame.InputBegan:Connect(function(ip)
        if (ip.UserInputType == Enum.UserInputType.MouseButton1 or ip.UserInputType == Enum.UserInputType.Touch) then
            dragging = true mousePos = ip.Position framePos = parent.Position
            ip.Changed:Connect(function() if ip.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    frame.InputChanged:Connect(function(ip) if (ip.UserInputType == Enum.UserInputType.MouseMovement or ip.UserInputType == Enum.UserInputType.Touch) then dragInput = ip end end)
    input.InputChanged:Connect(function(ip)
        if ip == dragInput and dragging then
            local delta = ip.Position - mousePos
            parent.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
        end
    end)
end

