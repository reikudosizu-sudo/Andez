local activeNotifications = 0
local function SendNotification(title, text, duration)
    activeNotifications = activeNotifications + 1
    local currentNotifIndex = activeNotifications
    
    local NotifFrame = Instance.new("Frame", NotifyGui)
    NotifFrame.Size = UDim2.new(0, 210, 0, 60)
    NotifFrame.Position = UDim2.new(1, 50, 0.85, -(activeNotifications * 70))
    NotifFrame.BackgroundColor3 = Miyako_Theme.Background
    NotifFrame.BorderSizePixel = 0
    NotifFrame.ZIndex = 1000000
    Instance.new("UICorner", NotifFrame).CornerRadius = UDim.new(0, 10)
    
    local nStroke = Instance.new("UIStroke", NotifFrame)
    nStroke.Color = Miyako_Theme.SchemeColor
    nStroke.Thickness = 2

    local nTitle = Instance.new("TextLabel", NotifFrame)
    nTitle.Size = UDim2.new(1, -20, 0, 20)
    nTitle.Position = UDim2.new(0, 10, 0, 8)
    nTitle.BackgroundTransparency = 1
    nTitle.Text = tostring(title):upper()
    nTitle.TextColor3 = Miyako_Theme.SchemeColor
    nTitle.Font = Enum.Font.GothamBold
    nTitle.TextSize = 13
    nTitle.TextXAlignment = "Left"

    local nText = Instance.new("TextLabel", NotifFrame)
    nText.Size = UDim2.new(1, -20, 0, 25)
    nText.Position = UDim2.new(0, 10, 0, 28)
    nText.BackgroundTransparency = 1
    nText.Text = tostring(text)
    nText.TextColor3 = Color3.fromRGB(255, 255, 255)
    nText.Font = Enum.Font.GothamMedium
    nText.TextSize = 11
    nText.TextXAlignment = "Left"
    nText.TextWrapped = true

    tween:Create(NotifFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -230, 0.85, -(currentNotifIndex * 70))
    }):Play()
    
    task.delay(duration or 4, function()
        local slideOut = tween:Create(NotifFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 50, 0.85, NotifFrame.Position.Y.Offset)
        })
        slideOut:Play()
        slideOut.Completed:Connect(function()
            NotifFrame:Destroy()
            activeNotifications = activeNotifications - 1
        end)
    end)
end

